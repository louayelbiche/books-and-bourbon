{
  "name": "@runwell/shared-tools",
  "version": "1.0.0",
  "description": "Shared tool definitions for BIB agents and local skills",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./detection": {
      "types": "./dist/detection/index.d.ts",
      "import": "./dist/detection/index.js"
    },
    "./brand-analysis": {
      "types": "./dist/brand-analysis/index.d.ts",
      "import": "./dist/brand-analysis/index.js"
    },
    "./llm-client": {
      "types": "./dist/llm-client/index.d.ts",
      "import": "./dist/llm-client/index.js"
    },
    "./storage": {
      "types": "./dist/storage/index.d.ts",
      "import": "./dist/storage/index.js"
    },
    "./derja": {
      "types": "./dist/derja/index.d.ts",
      "import": "./dist/derja/index.js"
    },
    "./security": {
      "types": "./dist/security/index.d.ts",
      "import": "./dist/security/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "better-sqlite3": "^12.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
